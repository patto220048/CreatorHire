# -----------------------------------------------------------------------------
# CreatorHire - Cấu hình Biến Môi Trường (Environment Variables)
# Copy file này thành .env.local và điền các giá trị thực tế để kết nối Database.
# -----------------------------------------------------------------------------

# Supabase API (Dùng cho cả Client và Server trong Next.js)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# PostgreSQL Connection String (Dành cho việc kết nối trực tiếp hoặc các tool ORM như Prisma/Drizzle)
# - DATABASE_URL: Thường kết nối qua Transaction Pooler (cổng 5432 hoặc 6543)
# - DIRECT_URL: Kết nối trực tiếp bypass Pooler (cổng 5432) để chạy migrations
DATABASE_URL=postgresql://postgres:your-db-password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:your-db-password@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# Cấu hình Cổng Thanh Toán PayOS (VietQR)
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key
PAYOS_RETURN_URL=http://localhost:3000/payment/success
PAYOS_CANCEL_URL=http://localhost:3000/payment/cancel
